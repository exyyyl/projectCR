{
    "name": "projectcr",
    "version": "0.1.2",
    "description": "ProjectCR",
    "main": "out/main/index.js",
    "author": "",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/exyyyl/projectCR.git"
    },
    "build": {
        "appId": "com.projectcr",
        "productName": "projectCR",
        "icon": "resources/icon.png",
        "publish": [
            {
                "provider": "github",
                "owner": "exyyyl",
                "repo": "projectCR",
                "releaseType": "release"
            }
        ],
        "win": {
            "target": ["nsis"],
            "icon": "resources/icon.png",
            "executableName": "projectCR"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "projectCR",
            "installerIcon": "resources/icon.png",
            "uninstallerIcon": "resources/icon.png",
            "installerHeaderIcon": "resources/icon.png"
        }
    },
    "scripts": {
        "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "publish": "electron-vite build && electron-builder --publish always",
        "rebuild": "electron-rebuild -f -w better-sqlite3"
    },
    "dependencies": {
        "@base-ui-components/react": "^1.0.0-alpha.4",
        "@base-ui/react": "^1.4.1",
        "@electron-toolkit/utils": "^3.0.0",
        "axios": "^1.6.7",
        "better-sqlite3": "^9.4.3",
        "electron-log": "^5.4.3",
        "electron-updater": "^6.8.3",
        "lucide-react": "^1.14.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@types/better-sqlite3": "^7.6.8",
        "@types/node": "^20.11.5",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "electron": "^28.2.0",
        "electron-builder": "^26.8.1",
        "electron-vite": "^2.0.0",
        "postcss": "^8.4.33",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3",
        "vite": "^5.0.12"
    }
}
